project Snake is
   for Source_Dirs use ("src", "tests");
   for Main use ("main.adb", "snake_game_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-O0", "-g");
   end Compiler;

   package Builder is
      for Executable ("main.adb") use "snake";
      for Executable ("snake_game_tests.adb") use "snake_game_tests";
   end Builder;
end Snake;
